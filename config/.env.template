# ─────────────────────────────────────────────────────────────────────────────
#  Innerflect — config/.env.template
#  Copy to config/.env and fill in values. Never commit config/.env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Project ───────────────────────────────────────────────────────────────────
SITE_DIR=PLACEHOLDER          # absolute path — set by setup.sh
SITE_NAME=innerflect

# ── Ports ────────────────────────────────────────────────────────────────────
WEB_PORT=8090
API_PORT=8000
CHAT_PORT=8001

# ── Domain ───────────────────────────────────────────────────────────────────
DOMAIN=localhost
NGROK_DOMAIN=                 # e.g. your-slug.ngrok-free.dev

# ── Tunnel ───────────────────────────────────────────────────────────────────
# Set TUNNEL_UUID to your Cloudflare tunnel UUID for a permanent URL.
# Leave as NGROK to use ngrok instead.
TUNNEL_UUID=NGROK
CF_BIN=/usr/local/bin/cloudflared

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
INNERFLECT_ADMIN_TOKEN=

# ── Notifications ────────────────────────────────────────────────────────────
# Discord webhook URL for contact alerts and daily reports (optional)
DISCORD_WEBHOOK=

# ── AI (optional — TherapySpace server-side fallback) ────────────────────────
OPENROUTER_API_KEY=

# ── Redis (optional — caching, rate limiting, presence) ──────────────────────
# Free tier: redis.io/try-free (30 MB, no credit card)
REDIS_HOST=
REDIS_PORT=6379
REDIS_USER=default
REDIS_PASS=

# ── Performance ──────────────────────────────────────────────────────────────
# Workers auto-detected from RAM. Override here if needed (1 = low-RAM/Android).
# WORKERS_OVERRIDE=1

# ── Chat ─────────────────────────────────────────────────────────────────────
CHAT_MSG_TTL=604800           # seconds to keep chat messages (7 days)

      { name: 'SmolLM2', size: '360MB', badge: '⚡ Instant' },
      { name: 'Llama 3.2', size: '700MB', badge: '🚀 Fast' },
      { name: 'Phi-3.5-mini', size: '2.3GB', badge: '⭐ Best' },
